#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
cd "$ROOT"
# Load local secrets (Telegram/LINE tokens) if present; gitignored, never committed.
eval "$(python3 -m company_kernel.secrets export-env 2>/dev/null || true)"  # OS keychain first (company-secrets)
[ -f "$ROOT/config/secrets.env" ] && set -a && . "$ROOT/config/secrets.env" && set +a  # local file overrides during migration
python3 -m company_kernel.company_daemon "$@"
