<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.openclaw.company-kernel.dashboard</string>
  <key>ProgramArguments</key>
  <array>
    <string>__COMPANY_KERNEL_ROOT__/bin/company-dashboard-server</string>
  </array>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>__COMPANY_KERNEL_ROOT__</string>
  <key>StandardOutPath</key>
  <string>__COMPANY_KERNEL_ROOT__/logs/company-dashboard.launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__COMPANY_KERNEL_ROOT__/logs/company-dashboard.launchd.err.log</string>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
