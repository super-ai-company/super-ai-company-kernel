{
  "version": 2,
  "interval_seconds": 30,
  "heartbeat_agents": [],
  "heartbeat_runtimes": [],
  "sync_openclaw_runtime": true,
  "sync_openclaw_heartbeats": true,
  "import_openclaw_native_results": true,
  "run_repair": true,
  "run_scheduler": true,
  "run_supervisor_delivery_loop": true,
  "run_retries": true,
  "max_retries_per_tick": 5,
  "watchdog": {
    "enabled": true,
    "unclaimed_minutes": 10,
    "notify": "owner",
    "from": "openclaw-main",
    "max_alerts_per_tick": 5
  },
  "backup": {
    "enabled": true,
    "interval_hours": 24,
    "keep": 14
  },
  "reconcile_status": {
    "enabled": true,
    "interval_hours": 6
  },
  "auto_recover": {
    "enabled": true,
    "interval_minutes": 10,
    "max_per_run": 3
  },
  "adapter_workers": [
    {
      "agent": "codex",
      "enabled": true,
      "command": "company-codex-adapter",
      "args": [
        "--execute",
        "--sandbox",
        "danger-full-access",
        "--model",
        "gpt-5.5",
        "--timeout-seconds",
        "1800"
      ],
      "max_tasks_per_tick": 1,
      "retry_policy": {
        "max_attempts": 3,
        "base_delay_seconds": 60,
        "max_delay_seconds": 900
      }
    },
    {
      "agent": "hermes",
      "enabled": true,
      "command": "company-hermes-adapter",
      "args": [],
      "max_tasks_per_tick": 1,
      "retry_policy": {
        "max_attempts": 3,
        "base_delay_seconds": 60,
        "max_delay_seconds": 900
      }
    },
    {
      "agent": "nestcar",
      "enabled": true,
      "command": "company-openclaw-adapter",
      "args": [
        "--execute"
      ],
      "max_tasks_per_tick": 1,
      "retry_policy": {
        "max_attempts": 3,
        "base_delay_seconds": 60,
        "max_delay_seconds": 900
      }
    },
    {
      "agent": "claude",
      "enabled": true,
      "command": "company-claude-adapter",
      "args": [
        "--execute",
        "--permission-mode",
        "bypassPermissions"
      ],
      "max_tasks_per_tick": 1,
      "retry_policy": {
        "max_attempts": 3,
        "base_delay_seconds": 60,
        "max_delay_seconds": 900
